#!/bin/sh
set -e

# Execute everything under www-data
if [ -n "$HOST_UID" ] && [ -n "$HOST_GID" ]; then
    groupmod -o -g "$HOST_GID" www-data
    usermod -o -u "$HOST_UID" www-data
fi

# No frontend installed. Performing installation
if [ ! -f package.json ]; then
    cd ..
    npm create -y vue@latest frontend -- --ts --router --pinia --eslint
    cd frontend
    npm install
    npm pkg set scripts.dev="vite --host 0.0.0.0"
fi

exec "$@"